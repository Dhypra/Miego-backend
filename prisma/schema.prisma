generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Order {
  id           String      @id @default(cuid())
  customerName String      @map("customer_name")
  tableNumber  String      @map("table_number")
  subtotal     Int
  fee          Int
  total        Int
  payStatus    String      @default("pending") @map("pay_status")
  orderStatus  String      @default("new") @map("order_status")
  paymentType  String?     @map("payment_type")
  snapToken    String?     @map("snap_token")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  items        OrderItem[]
  payment      Payment?

  @@map("orders")
}

model OrderItem {
  id      Int    @id @default(autoincrement())
  orderId String @map("order_id")
  name    String
  emoji   String @default("🍜")
  qty     Int
  price   Int
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Payment {
  id                String    @id @default(cuid())
  orderId           String    @unique @map("order_id")
  midtransOrderId   String?   @map("midtrans_order_id")
  transactionStatus String?   @map("transaction_status")
  paymentType       String?   @map("payment_type")
  grossAmount       String?   @map("gross_amount")
  fraudStatus       String?   @map("fraud_status")
  paidAt            DateTime? @map("paid_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model MenuItem {
  id        Int      @id @default(autoincrement())
  name      String
  desc      String
  price     Int
  category  String
  emoji     String   @default("🍜")
  spicy     Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("menu_items")
}
